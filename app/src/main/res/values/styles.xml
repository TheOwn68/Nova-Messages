<resources>

    <style name="AppTheme" parent="AppTheme.Base">
        <!-- Primary/secondary/tertiary text colors -->
        <item name="android:textColorPrimary">#000000</item>
        <item name="android:textColorSecondary">#66000000</item>
        <item name="android:textColorTertiary">#40000000</item>

        <!-- Optional: ensure controls and foreground use dark color -->
        <item name="android:colorForeground">#000000</item>

        <!-- Icon colors for Toolbar -->
        <item name="colorControlNormal">#FFFFFF</item>

        <!-- Modern Activity Transitions -->
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowAnimationStyle">@style/WindowAnimation</item>
    </style>

    <style name="WindowAnimation">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>

    <style name="roundedImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/normal_margin</item>
    </style>

    <style name="NovaToolbarTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="NovaPopupTheme" parent="ThemeOverlay.AppCompat.Light">
        <item name="android:background">#FFFFFF</item>
        <item name="android:textColor">#000000</item>
        <item name="android:textColorPrimary">#000000</item>
        <item name="android:textColorSecondary">#000000</item>
        <item name="android:itemTextAppearance">@style/NovaMenuText</item>
        <item name="android:actionMenuTextColor">#000000</item>
    </style>

    <style name="NovaMenuText" parent="TextAppearance.AppCompat.Widget.DropDownItem">
        <item name="android:textColor">#000000</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
